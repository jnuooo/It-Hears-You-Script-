-- Highlight & Name Tag Engine
local function applyESP(instance, color, displayName, cacheTable)
    if not instance then return end
    if cacheTable[instance] then return end

    -- Create Visual Highlight
    local highlight = Instance.new("Highlight")
    highlight.FillColor = color
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.45
    highlight.OutlineTransparency = 0.1
    highlight.Adornee = instance
    highlight.Parent = instance

    -- Create 3D Text Label
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.AlwaysOnTop = true
    billboard.Adornee = instance:IsA("Model") and (instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart")) or instance
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = color
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.Text = displayName
    label.TextStrokeTransparency = 0.4
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Parent = billboard
    
    billboard.Parent = instance

    cacheTable[instance] = {Highlight = highlight, Billboard = billboard}
end

local function removeESP(instance, cacheTable)
    if cacheTable[instance] then
        if cacheTable[instance].Highlight then
            cacheTable[instance].Highlight:Destroy()
        end
        if cacheTable[instance].Billboard then
            cacheTable[instance].Billboard:Destroy()
        end
        cacheTable[instance] = nil
    end
end

-- 1. Doors ESP Logic
local doorsConnection
local function toggleDoorsESP(state)
    ESP_Toggles.Doors = state
    if state then
        local folder = getDoorsFolder()
        if folder then
            for _, child in ipairs(folder:GetChildren()) do
                applyESP(child, Color3.fromRGB(255, 110, 0), "Door", ESP_Cache.Doors)
            end
            doorsConnection = folder.ChildAdded:Connect(function(child)
                task.wait(0.2)
                if ESP_Toggles.Doors then
                    applyESP(child, Color3.fromRGB(255, 110, 0), "Door", ESP_Cache.Doors)
                end
            end)
        end
    else
        if doorsConnection then doorsConnection:Disconnect() doorsConnection = nil end
        for inst, _ in pairs(ESP_Cache.Doors) do
            removeESP(inst, ESP_Cache.Doors)
        end
    end
end

-- 2. Player ESP Logic
local playerAddedConn, playerRemovingConn
local charConnections = {}

local function handlePlayerChar(player, char)
    if not char then return end
    applyESP(char, Color3.fromRGB(0, 130, 255), player.Name, ESP_Cache.Players)
end

local function togglePlayerESP(state)
    ESP_Toggles.Players = state
    if state then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if player.Character then
                    handlePlayerChar(player, player.Character)
                end
                charConnections[player] = player.CharacterAdded:Connect(function(char)
                    task.wait(0.5)
                    if ESP_Toggles.Players then
                        handlePlayerChar(player, char)
                    end
                end)
            end
        end

        playerAddedConn = Players.PlayerAdded:Connect(function(player)
            charConnections[player] = player.CharacterAdded:Connect(function(char)
                task.wait(0.5)
                if ESP_Toggles.Players then
                    handlePlayerChar(player, char)
                end
            end)
        end)

        playerRemovingConn = Players.PlayerRemoving:Connect(function(player)
            if charConnections[player] then
                charConnections[player]:Disconnect()
                charConnections[player] = nil
            end
            if player.Character then
                removeESP(player.Character, ESP_Cache.Players)
            end
        end)
    else
        if playerAddedConn then playerAddedConn:Disconnect() playerAddedConn = nil end
        if playerRemovingConn then playerRemovingConn:Disconnect() playerRemovingConn = nil end
        for player, conn in pairs(charConnections) do
            conn:Disconnect()
        end
        table.clear(charConnections)
        for inst, _ in pairs(ESP_Cache.Players) do
            removeESP(inst, ESP_Cache.Players)
        end
    end
end

-- 3. Tool ESP Logic
local toolAddedConn, spawnedItemsConn

local function checkAndApplyTool(child)
    if child:IsA("Tool") then
        applyESP(child, Color3.fromRGB(150, 150, 150), child.Name, ESP_Cache.Tools)
    end
end

local function checkAndApplySpawnedItem(child)
    applyESP(child, Color3.fromRGB(150, 150, 150), child.Name, ESP_Cache.Tools)
end

local function toggleToolESP(state)
    ESP_Toggles.Tools = state
    if state then
        -- Scan Workspace Tools
        for _, child in ipairs(Workspace:GetChildren()) do
            checkAndApplyTool(child)
        end
        toolAddedConn = Workspace.ChildAdded:Connect(function(child)
            task.wait(0.2)
            if ESP_Toggles.Tools then
                checkAndApplyTool(child)
            end
        end)

        -- Scan Spawned Items Folder
        local spawnedFolder = getSpawnedItemsFolder()
        if spawnedFolder then
            for _, child in ipairs(spawnedFolder:GetChildren()) do
                checkAndApplySpawnedItem(child)
            end
            spawnedItemsConn = spawnedFolder.ChildAdded:Connect(function(child)
                task.wait(0.2)
                if ESP_Toggles.Tools then
                    checkAndApplySpawnedItem(child)
                end
            end)
        end
    else
        if toolAddedConn then toolAddedConn:Disconnect() toolAddedConn = nil end
        if spawnedItemsConn then spawnedItemsConn:Disconnect() spawnedItemsConn = nil end
        for inst, _ in pairs(ESP_Cache.Tools) do
            removeESP(inst, ESP_Cache.Tools)
        end
    end
end

-- 4. Entities ESP Logic
local entitiesConnection
local function toggleEntitiesESP(state)
    ESP_Toggles.Entities = state
