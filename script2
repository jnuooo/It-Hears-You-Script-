-- Deleting Roblox HealthBar Disable Script
local function removeHealthBarScript()
    local function destroyIn(parent)
        if parent then
            local scriptObj = parent:FindFirstChild("HealthBarRobloxDisable", true)
            if scriptObj and scriptObj:IsA("LocalScript") then
                scriptObj:Destroy()
            end
        end
    end
    destroyIn(StarterGui)
    if LocalPlayer then
        destroyIn(LocalPlayer:FindFirstChildOfClass("PlayerGui"))
    end
end
